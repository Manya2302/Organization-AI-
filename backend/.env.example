# ===================================
# SecureVault AI Backend - Environment
# ===================================

# Server Configuration
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ===================================
# PostgreSQL Database Configuration
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securevault_db
DB_USER=postgres
DB_PASSWORD=SecureVault@2025
DB_SSL=false

# ===================================
# JWT Authentication Secrets
# ===================================
JWT_SECRET=securevault_ai_jwt_super_secret_key_2025_enterprise_grade
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=securevault_ai_refresh_secret_key_2025
JWT_REFRESH_EXPIRES_IN=7d

# ===================================
# Local Ollama AI Configuration
# ===================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120000

# ===================================
# ChromaDB Vector Database
# ===================================
CHROMA_BASE_URL=http://localhost:8000
CHROMA_COLLECTION=securevault_documents

# ===================================
# File Upload & Storage
# ===================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,xlsx,pptx,txt,png,jpg,jpeg,csv

# ===================================
# OCR Configuration (PaddleOCR/Tesseract)
# ===================================
OCR_ENGINE=paddle
PADDLEOCR_API_URL=http://localhost:8866
TESSERACT_LANG=eng

# ===================================
# Security & Rate Limiting
# ===================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
OTP_EXPIRY_MINUTES=10

# ===================================
# Logging
# ===================================
LOG_LEVEL=info
LOG_FILE=./logs/securevault.log
